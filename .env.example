# ============================================================
# VARIABLES DE ENTORNO - TIEMPO BAKERY
# ============================================================
# Copia este archivo como .env y completa los valores.
# NUNCA subas .env al repositorio.

# ------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------

# URL de Prisma Accelerate (usada por el cliente en la app y en Vercel)
# Formato: prisma+postgres://accelerate.prisma-data.net/?api_key=...
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=..."

# URL directa a PostgreSQL (usada por el CLI de Prisma para migraciones en local)
# Formato: postgres://usuario:password@host:puerto/nombre_db?sslmode=require
DIRECT_URL="postgres://..."

# ------------------------------------------------------------
# STRIPE (pagos)
# ------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ADMIN_PASSWORD="cambiar_en_produccion"
JWT_SECRET="cambiar_en_produccion"
