# ============================================================
# VARIABLES DE ENTORNO - TIEMPO BAKERY
# ============================================================
# Copia este archivo como .env.local y completa los valores.
# NUNCA subas .env.local al repositorio.

# ------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------

# URL de Prisma Accelerate (usada por el cliente en la app y en Vercel)
# Formato: prisma+postgres://accelerate.prisma-data.net/?api_key=...
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=..."

# URL directa a PostgreSQL (usada por el CLI de Prisma para migraciones en local)
# Formato: postgres://usuario:password@host:puerto/nombre_db?sslmode=require
DIRECT_URL="postgres://..."

# ------------------------------------------------------------
# STRIPE (pagos)
# ------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ------------------------------------------------------------
# MERCADO PAGO (pagos)
# ------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NEXT_PUBLIC_URL="http://localhost:3000"
ADMIN_PASSWORD="cambiar_en_produccion"
JWT_SECRET="cambiar_en_produccion"

# ------------------------------------------------------------
# SUPABASE STORAGE (uploads persistentes en web)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"

NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."
